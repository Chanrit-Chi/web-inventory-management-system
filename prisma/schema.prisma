generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  role          Role      @default(SELLER)
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum Role {
  SELLER
  ADMIN
  MANAGER
}

// Inventory section

model Product {
  id                   String                @id @default(cuid())
  sku                  String                @unique
  name                 String
  image                String?
  description          String
  unitId               Int
  unit                 unit                  @relation(fields: [unitId], references: [id])
  variants             ProductVariant[]
  productAttributes    ProductOnAttribute[]
  orderDetail          OrderDetail[]
  purchaseOrderDetails PurchaseOrderDetail[]
  categoryId           Int
  category             Category              @relation(fields: [categoryId], references: [id])
  supplier             Supplier[]
  isActive             ProductStatus         @default(ACTIVE)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([categoryId])
  @@index([isActive])
  @@index([name])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model unit {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Supplier {
  id             String          @id @default(cuid())
  name           String          @default("")
  email          String          @unique
  phone          String
  address        String
  products       Product[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id])
  productId String
  sku       String  @unique

  costPrice    Decimal @default(0) @db.Decimal(10, 2)
  sellingPrice Decimal @default(0) @db.Decimal(10, 2)

  stock         Int      @default(0)
  reservedStock Int      @default(0)
  reorderLevel  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  attributes           ProductVariantAttribute[]
  orderDetail          OrderDetail[]
  stockMovements       StockMovement[]
  purchaseOrderDetails PurchaseOrderDetail[]

  @@index([stock]) // Find low stock quickly
  @@index([productId, isActive]) // Active variants for a product
}

//For future extensibility, price history can be tracked in a separate model
// model PriceHistory {
//   id           Int      @id @default(autoincrement())
//   variantId    Int
//   costPrice    Decimal  @db.Decimal(10, 2)
//   sellingPrice Decimal  @db.Decimal(10, 2)
//   effectiveFrom DateTime @default(now())
//   variant      ProductVariant @relation(fields: [variantId], references: [id])
// }

model ProductVariantAttribute {
  id        Int @id @default(autoincrement())
  variantId Int
  valueId   Int

  variant ProductVariant        @relation(fields: [variantId], references: [id])
  value   ProductAttributeValue @relation(fields: [valueId], references: [id])

  @@unique([variantId, valueId])
}

model ProductAttributeValue {
  id          Int    @id @default(autoincrement())
  value       String // Red, Blue, M, L
  attributeId Int

  attribute    ProductAttribute          @relation(fields: [attributeId], references: [id])
  variantLinks ProductVariantAttribute[]

  @@unique([attributeId, value])
}

model ProductAttribute {
  id   Int    @id @default(autoincrement())
  name String @unique // Size, Color

  values   ProductAttributeValue[]
  products ProductOnAttribute[]
}

model ProductOnAttribute {
  productId   String
  attributeId Int

  product   Product          @relation(fields: [productId], references: [id])
  attribute ProductAttribute @relation(fields: [attributeId], references: [id])

  @@id([productId, attributeId])
}

model StockMovement {
  id              Int               @id @default(autoincrement())
  variant         ProductVariant    @relation(fields: [variantId], references: [id])
  variantId       Int
  movementType    StockMovementType
  quantity        Int
  previousStock   Int
  newStock        Int
  orderId         Int?
  purchaseOrderId Int?
  reason          String?
  createdAt       DateTime          @default(now())
  createdBy       String?

  @@index([variantId])
  @@index([createdAt])
}

model Category {
  id          Int       @id @default(autoincrement())
  product     Product[]
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices   Invoice[]
  quotations Quotation[]

  @@index([name])
}

model Order {
  id              Int           @id @default(autoincrement())
  customer        Customer      @relation(fields: [customerId], references: [id])
  orderDetail     OrderDetail[]
  customerId      String
  totalPrice      Decimal       @default(0) @db.Decimal(10, 2)
  status          orderStatus   @default(COMPLETED)
  paymentMethodId Int
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  discountPercent Int           @default(0)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2)
  taxPercent      Int           @default(0)
  taxAmount       Decimal       @default(0) @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  invoice         Invoice? // One-to-one relation
  quotation       Quotation?

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderDetail {
  id        Int            @id @default(autoincrement())
  order     Order          @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product        @relation(fields: [productId], references: [id])
  productId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  variantId Int
  unitPrice Decimal        @default(0) @db.Decimal(10, 2)
  quantity  Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model PaymentMethod {
  id        Int      @id @default(autoincrement())
  name      String
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrder {
  id                   Int                   @id @default(autoincrement())
  supplier             Supplier              @relation(fields: [supplierId], references: [id])
  supplierId           String
  status               orderStatus           @default(COMPLETED)
  totalAmount          Decimal               @default(0) @db.Decimal(10, 2)
  purchaseOrderDetails PurchaseOrderDetail[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model PurchaseOrderDetail {
  id              Int            @id @default(autoincrement())
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId Int
  product         Product        @relation(fields: [productId], references: [id])
  productId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  variantId       Int
  unitPrice       Int            @default(0)
  quantity        Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique

  //relationship
  order      Order?   @relation(fields: [orderId], references: [id])
  orderId    Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  //Invoice details
  status     InvoiceStatus @default(DRAFT)
  issuedDate DateTime      @default(now())
  dueDate    DateTime?

  subtotal        Decimal @default(0) @db.Decimal(10, 2)
  taxPercent      Int     @default(0)
  taxAmount       Decimal @default(0) @db.Decimal(10, 2)
  discountPercent Int     @default(0)
  discountAmount  Decimal @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal @default(0) @db.Decimal(10, 2)

  //items
  invoiceItems InvoiceItem[]

  notes     String?
  terms     String? // Payment terms
  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([issuedDate])
  @@index([invoiceNumber])
}

model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String

  // Product Details (copied at time of invoice creation)
  productId   String
  productName String // Snapshot of product name
  variantId   Int?
  sku         String // Snapshot of SKU

  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(10, 2) // quantity * unitPrice

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quotation {
  id              String @id @default(cuid())
  quotationNumber String @unique // QUO-2024-001

  // Relations
  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  // Quote Details
  issueDate  DateTime @default(now())
  validUntil DateTime // Quote expiration

  // Financial Data
  subtotal        Decimal @db.Decimal(10, 2)
  discountPercent Int     @default(0)
  discountAmount  Decimal @default(0) @db.Decimal(10, 2)
  taxPercent      Int     @default(0)
  taxAmount       Decimal @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal @db.Decimal(10, 2)

  // Status
  status QuotationStatus @default(DRAFT)

  // Line Items
  quotationItems QuotationItem[]

  // Relations to orders (when quote is accepted)
  convertedToOrder Order? @relation(fields: [convertedOrderId], references: [id])
  convertedOrderId Int?   @unique

  // Metadata
  notes     String?
  terms     String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([issueDate])
  @@index([quotationNumber])
}

model QuotationItem {
  id          Int       @id @default(autoincrement())
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String

  productId   String
  productName String
  variantId   Int?
  sku         String

  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//Handle image uploads
model Upload {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  url       String
  status    String // "TEMP" | "CONFIRMED"
  userId    String
  createdAt DateTime @default(now())
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum orderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum StockMovementType {
  INITIAL
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  DAMAGE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  REFUNDED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}
