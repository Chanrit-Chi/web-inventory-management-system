//   variant      ProductVariant @relation(fields: [variantId], references: [id])
// }

model ProductVariantAttribute {
  id        Int @id @default(autoincrement())
  variantId Int
  valueId   Int

  variant ProductVariant        @relation(fields: [variantId], references: [id])
  value   ProductAttributeValue @relation(fields: [valueId], references: [id])

  @@unique([variantId, valueId])
}

model ProductAttributeValue {
  id           Int     @id @default(autoincrement())
  value        String // red, blue, m, l
  displayValue String  @default("") // Red, Blue, M, L
  colorHex     String? // For color attributes
  sortOrder    Int     @default(0)
  attributeId  Int

  attribute    ProductAttribute          @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variantLinks ProductVariantAttribute[]

  @@unique([attributeId, value])
}

enum AttributeType {
  SELECT
  COLOR
  TEXT
}

model ProductAttribute {
  id          Int           @id @default(autoincrement())
  name        String        @unique // size, color - internal name
  displayName String        @default("") // Size, Color - display name
  type        AttributeType @default(SELECT)
  isRequired  Boolean       @default(false)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt

  values   ProductAttributeValue[]
  products ProductOnAttribute[]
}

model ProductOnAttribute {
  productId   String
  attributeId Int

  product   Product          @relation(fields: [productId], references: [id])
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([productId, attributeId])
}

model StockMovement {
  id              Int               @id @default(autoincrement())
  variant         ProductVariant    @relation(fields: [variantId], references: [id])
  variantId       Int
  movementType    StockMovementType
  quantity        Int
  previousStock   Int
  newStock        Int
  orderId         Int?
  purchaseOrderId Int?
  reason          String?
  createdAt       DateTime          @default(now())
  createdBy       String?

  @@index([variantId])
  @@index([createdAt])
}

model Category {
  id          Int       @id @default(autoincrement())
  product     Product[]
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices   Invoice[]
  quotations Quotation[]

  @@index([name])
}

model Order {
  id              Int           @id @default(autoincrement())
  customer        Customer      @relation(fields: [customerId], references: [id])
  orderDetail     OrderDetail[]
  customerId      String
  totalPrice      Decimal       @default(0) @db.Decimal(10, 2)
  status          orderStatus   @default(COMPLETED)
  paymentMethodId Int
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  discountPercent Int           @default(0)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2)
  taxPercent      Int           @default(0)
  taxAmount       Decimal       @default(0) @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  invoice         Invoice? // One-to-one relation
  quotation       Quotation?

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderDetail {
  id        Int            @id @default(autoincrement())
  order     Order          @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product        @relation(fields: [productId], references: [id])
  productId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  variantId Int
  unitPrice Decimal        @default(0) @db.Decimal(10, 2)
  quantity  Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model PaymentMethod {
  id        Int       @id @default(autoincrement())
  name      String
  orders    Order[]
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ExpenseCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  expenses    Expense[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Expense {
  id              String          @id @default(cuid())
  amount          Decimal         @db.Decimal(10, 2)
  description     String
  expenseDate     DateTime        @default(now())
  categoryId      Int
  category        ExpenseCategory @relation(fields: [categoryId], references: [id])
  paymentMethodId Int?
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  referenceNo     String?
  notes           String?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([expenseDate])
  @@index([categoryId])
  @@index([paymentMethodId])
}

model PurchaseOrder {
  id                   Int                   @id @default(autoincrement())
  supplier             Supplier              @relation(fields: [supplierId], references: [id])
  supplierId           String
  status               orderStatus           @default(COMPLETED)
  totalAmount          Decimal               @default(0) @db.Decimal(10, 2)
  purchaseOrderDetails PurchaseOrderDetail[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model PurchaseOrderDetail {
  id              Int            @id @default(autoincrement())
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId Int
  product         Product        @relation(fields: [productId], references: [id])
  productId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  variantId       Int
  unitPrice       Int            @default(0)
  quantity        Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique

  //relationship
  order      Order?   @relation(fields: [orderId], references: [id])
  orderId    Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  //Invoice details
  status     InvoiceStatus @default(DRAFT)
  issuedDate DateTime      @default(now())
  dueDate    DateTime?

  subtotal        Decimal @default(0) @db.Decimal(10, 2)
  taxPercent      Int     @default(0)
  taxAmount       Decimal @default(0) @db.Decimal(10, 2)
  discountPercent Int     @default(0)
  discountAmount  Decimal @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal @default(0) @db.Decimal(10, 2)

  //items
  invoiceItems InvoiceItem[]

  notes     String?
  terms     String? // Payment terms
  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([issuedDate])
  @@index([invoiceNumber])
}

model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String

  // Product Details (copied at time of invoice creation)
  productId   String
  productName String // Snapshot of product name
  variantId   Int?
  sku         String // Snapshot of SKU

  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(10, 2) // quantity * unitPrice

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quotation {
  id              String @id @default(cuid())
  quotationNumber String @unique // QUO-2024-001

  // Relations
  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  // Quote Details
  issueDate  DateTime @default(now())
  validUntil DateTime // Quote expiration

  // Financial Data
  subtotal        Decimal @db.Decimal(10, 2)
  discountPercent Int     @default(0)
  discountAmount  Decimal @default(0) @db.Decimal(10, 2)
  taxPercent      Int     @default(0)
  taxAmount       Decimal @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal @db.Decimal(10, 2)

  // Status
  status QuotationStatus @default(DRAFT)

  // Line Items
  quotationItems QuotationItem[]

  // Relations to orders (when quote is accepted)
  convertedToOrder Order? @relation(fields: [convertedOrderId], references: [id])
  convertedOrderId Int?   @unique

  // Metadata
  notes     String?
  terms     String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([issueDate])
  @@index([quotationNumber])
}

model QuotationItem {
  id          Int       @id @default(autoincrement())
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String

  productId   String
  productName String
  variantId   Int?
  sku         String

  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//Handle image uploads
model Upload {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  url       String
  status    String // "TEMP" | "CONFIRMED"
  userId    String
  createdAt DateTime @default(now())
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum orderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum StockMovementType {
  INITIAL
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  DAMAGE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  REFUNDED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}
